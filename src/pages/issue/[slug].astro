  return issues.map((issue, idx) => {
    const newer = idx > 0 ? issues[idx - 1] : null;
    const older = idx < issues.length - 1 ? issues[idx + 1] : null;

    return {
      params: { slug: issue.slug },
      props: { issue, newer, older },
    };
  });
}

const { issue, newer, older } = Astro.props;
---

<Layout>
  <Fragment slot="head">
    <title>{`Issue ${issue.number} - ${siteTitle}`}</title>
    <meta name="description" content={issue.dek} />
  </Fragment>

  <style>
    /* ✅ Globals (bg, font, tokens, links) live in layout.astro */

    .wrap{
      max-width: var(--max);
      margin: 34px auto 60px;
      padding: 0 18px;
    }

    .divider{
      height:1px;
      background: rgba(0,0,0,.10);
      margin: 14px 0 0;
    }

    .kicker{
      font-size:.78rem;
      letter-spacing:.10em;
      text-transform: uppercase;
      opacity:.68;
      margin: 22px 0 8px;
    }

    h1{
      margin: 0 0 10px;
      letter-spacing: -0.02em;
      line-height: 1.14;
      font-size: 2.05rem;
      font-weight: 700;
      max-width: 72ch;
    }

    .dek{
      margin: 0 0 12px;
      opacity:.82;
      font-size: 1.06rem;
      line-height: 1.6;
      max-width: 70ch;
    }

    .metaRow{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      opacity:.68;
      font-size:.95rem;
      margin-bottom: 18px;
    }

    .dot{
      width:4px; height:4px;
      border-radius:999px;
      background: rgba(0,0,0,.32);
      display:inline-block;
      margin-top: 9px;
    }

    .layout{
      display:grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }

    @media (min-width: 920px){
      .layout{
        grid-template-columns: 1.9fr 1fr;
        align-items:start;
      }
    }

    .card{
      border:1px solid var(--line);
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow:hidden;
    }

    h2{
      margin: 0 0 8px;
      font-size: 1.05rem;
      font-weight: 750;
      letter-spacing: -0.01em;
    }

    .section{
      padding: 18px;
      border-top: 1px solid rgba(0,0,0,.06);
    }
    .section:first-child{ border-top: 0; }

    .section p{
      margin: 0;
      line-height: 1.75;
      font-size: 1.02rem;
      opacity: .92;
    }

    .section p + p{ margin-top: 10px; }

    .section ul{
      margin: 10px 0 0;
      padding-left: 18px;
      line-height: 1.7;
      opacity:.92;
    }

    .section li{ margin: 0 0 6px; }
    .section strong{ font-weight: 700; }

    .callout{
      background: rgba(213, 193, 162, .22);
      border: 1px solid rgba(0,0,0,.10);
      border-radius: 14px;
      padding: 14px;
      margin-top: 10px;
    }
    .callout h2{ margin-bottom: 8px; }

    .rail .block{ padding: 18px; }
    .rail .block + .block{ border-top: 1px solid rgba(0,0,0,.06); }

    .railTitle{
      font-size: .95rem;
      font-weight: 750;
      letter-spacing: -0.01em;
      margin: 0 0 10px;
    }

    .rail ul{
      margin: 0;
      padding-left: 18px;
      line-height: 1.7;
      opacity: .92;
    }

    .rail li{ margin: 0 0 6px; }

    /* ✅ button-sized */
    .formRow{
      display:flex;
      flex-direction:column;
      gap:10px;
      margin-top: 10px;
    }
    @media (min-width:560px){
      .formRow{
        flex-direction:row;
        align-items:stretch;
      }
    }

    .input{
      flex:1 1 auto;
      min-width:0;
      padding: 11px 12px;
      border-radius: 12px;
      border:1px solid var(--line);
      background:#fff;
      font-size: 1rem;
      outline:none;
    }
    .input:focus{ box-shadow: 0 0 0 3px rgba(0,0,0,.06); }

    .submit{
      flex:0 0 auto;
      width:auto;
      white-space:nowrap;
      padding: 11px 14px;
      border-radius: 12px;
      border:1px solid var(--line);
      background: rgba(0,0,0,.03);
      font-weight: 650;
      cursor: pointer;
      text-align:center;
    }

    .small{
      margin-top: 8px;
      font-size:.92rem;
      opacity:.70;
      line-height:1.35;
    }

    .bottomNav{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top: 16px;
    }

    .navLink{
      display:inline-block;
      padding:10px 12px;
      border-radius:12px;
      border:1px solid var(--line);
      background: rgba(0,0,0,.02);
      text-decoration:none;
      color:inherit;
    }
    .navLink:hover{ background: rgba(0,0,0,.04); }
  </style>

  <main class="container page">
    <div class="divider"></div>

    <div class="kicker">{`Issue ${issue.number}`}</div>
    <h1>{issue.title}</h1>
    <p class="dek">{issue.dek}</p>

    <div class="metaRow">
      <span>{issue.date}</span>
      <span class="dot" aria-hidden="true"></span>
      <span>{issue.readTime}</span>
    </div>

    <div class="layout">
      <section class="card">
        {issue.sections.map((s) => (
          <div class="section">
            {s.tone === "callout" ? (
              <div class="callout">
                <h2>{s.h}</h2>
                <div set:html={s.html}></div>
              </div>
            ) : (
              <>
                <h2>{s.h}</h2>
                <div set:html={s.html}></div>
              </>
            )}
          </div>
        ))}
      </section>

      <aside class="card rail">
        <div class="block">
          <div class="railTitle">Key signals</div>
          <ul>
            {issue.signals.map((t) => <li>{t}</li>)}
          </ul>
        </div>

        <div class="block">
          <div class="railTitle">Get the weekly text</div>
          <div style="opacity:.86; line-height:1.45;">
            One message when a new issue lands.
          </div>

          <form method="POST" action="/api/subscribe" class="formRow">
            <input
              class="input"
              type="tel"
              name="phone"
              inputmode="tel"
              autocomplete="tel"
              placeholder="Your mobile number"
              required
            />
            <button class="submit" type="submit">Keep me posted</button>
          </form>

          <div class="small">
            By submitting, you agree to receive occasional SMS updates. Reply STOP to unsubscribe.
          </div>
        </div>
      </aside>
    </div>

    <div class="bottomNav">
      {older ? (
        <a class="navLink" href={`/issue/${older.slug}`}>← Previous</a>
      ) : (
        <span class="navLink" style="opacity:.40; cursor:default;">← Previous</span>
      )}

      {newer ? (
        <a class="navLink" href={`/issue/${newer.slug}`}>Next →</a>
      ) : (
        <span class="navLink" style="opacity:.40; cursor:default;">Next →</span>
      )}

      <a class="navLink" href="/issue/archive">All issues</a>
    </div>
  </main>
</Layout>