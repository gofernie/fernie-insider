---
const nav = [
  { href: "/", label: "Latest" },
  { href: "/archive", label: "Archive" },
  { href: "/about", label: "About" },
];

const isActive = (href) => Astro.url.pathname === href;
---

<header class="site-header">
  <div class="container topbar">
    <a class="brand" href="/">Fernie Insider</a>

    <nav class="nav" aria-label="Primary">
      {nav.map((item) => (
        <a class:list={["link", isActive(item.href) && "is-active"]} href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>

    <button
      class="burger"
      type="button"
      aria-label="Toggle menu"
      aria-controls="primary-menu"
      aria-expanded="false"
      data-burger
    >
      <span class="burger-lines" aria-hidden="true"></span>
    </button>
  </div>

  <div class="container menu" id="primary-menu" hidden data-menu>
    <nav class="menu-inner" aria-label="Primary mobile">
      {nav.map((item) => (
        <a class:list={["menu-link", isActive(item.href) && "is-active"]} href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <script is:inline>
    (() => {
      const btn = document.querySelector("[data-burger]");
      const menu = document.querySelector("[data-menu]");
      if (!btn || !menu) return;

      const close = () => {
        btn.setAttribute("aria-expanded", "false");
        menu.hidden = true;
      };

      const toggle = () => {
        const open = btn.getAttribute("aria-expanded") === "true";
        btn.setAttribute("aria-expanded", String(!open));
        menu.hidden = open;
      };

      btn.addEventListener("click", toggle);

      menu.addEventListener("click", (e) => {
        const a = e.target.closest("a");
        if (a) close();
      });

      window.addEventListener("resize", () => {
        if (window.matchMedia("(min-width: 901px)").matches) close();
      });
    })();
  </script>

  <style is:global>
   .site-header{
  background: var(--bg);
  border-bottom: none;
  padding-top: 16px;   /* ✅ controls the space ABOVE the nav */
}

.topbar{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16px;
  padding:10px 0 12px; /* ✅ tighter overall vertical feel */
}

    .brand{
      font-weight:700;
      white-space:nowrap;
      line-height:1;
    }

    .nav{
      display:flex;
      align-items:center;
      gap:18px;
      white-space:nowrap;
    }

    .link{
      font-size:14px;
      color:var(--muted);
      padding:8px 0;
    }

    .link:hover{
      text-decoration:none;
      color:var(--ink);
    }

    .link.is-active{
      color:var(--ink);
      font-weight:600;
    }

    .burger{
      display:none;
      background:transparent;
      border:0;
      padding:8px;
      cursor:pointer;
      border-radius:12px;
    }

    .burger:focus-visible{
      outline:2px solid rgba(0,0,0,.22);
      outline-offset:2px;
    }

    .burger-lines{
      display:block;
      width:22px;
      height:2px;
      background:var(--ink);
      position:relative;
      border-radius:2px;
    }

    .burger-lines::before,
    .burger-lines::after{
      content:"";
      position:absolute;
      left:0;
      width:22px;
      height:2px;
      background:var(--ink);
      border-radius:2px;
    }

    .burger-lines::before{ top:-7px; }
    .burger-lines::after{ top:7px; }

    .menu{
      padding:0 0 14px;
    }

    .menu-inner{
      display:flex;
      flex-direction:column;
      gap:10px;
      padding-top:8px;
    }

    .menu-link{
      padding:12px 14px;
      border-radius:14px;
      background:rgba(255,255,255,.60);
      border:1px solid rgba(0,0,0,.10);
      color:var(--muted);
      font-size:15px;
    }

    .menu-link:hover{
      text-decoration:none;
      color:var(--ink);
      border-color: rgba(0,0,0,.14);
    }

    .menu-link.is-active{
      color:var(--ink);
      font-weight:600;
      border-color: rgba(0,0,0,.18);
      background:rgba(255,255,255,.78);
    }

    @media (max-width: 900px){
      .nav{ display:none; }
      .burger{ display:block; }
    }
  </style>
</header>